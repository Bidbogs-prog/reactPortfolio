# Contact form (api/contact.ts) — set these in Vercel → Project → Settings → Environment Variables
# Get an API key at https://resend.com (Account → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form submissions are delivered. Defaults to haythamchhilif@gmail.com.
# CONTACT_TO=you@example.com

# The "from" address. Until bidbogs.com is verified in Resend, leave this unset
# (defaults to onboarding@resend.dev, which can only deliver to your Resend
# account email). After verifying the domain, set e.g.:
# CONTACT_FROM=Haytham Chhilif <contact@bidbogs.com>
